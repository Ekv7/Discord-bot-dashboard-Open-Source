# Kopieren nach .env im Projektroot und Werte setzen (keine echten Secrets hier eintragen).
# Kurzüberblick: START.md

# --- Pflicht Discord / Bot ---
DISCORD_TOKEN=HIER_DISCORD_BOT_TOKEN_EINTRAGEN
DISCORD_CLIENT_ID=HIER_DISCORD_APPLICATION_ID_EINTRAGEN

# --- Dashboard (lokal oder hinter Reverse-Proxy / Tunnel) ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3847
TRUST_PROXY=true

# Öffentliche HTTPS-URL der Bot-API (ohne Slash am Ende)
DASHBOARD_PUBLIC_URL=https://bot.DEINE-DOMAIN.de
# Muss exakt zu Discord OAuth2 → Redirects passen (mit /api/v1 wenn du Versionierung nutzt)
DASHBOARD_OAUTH_REDIRECT_URI=https://bot.DEINE-DOMAIN.de/api/v1/auth/callback
# Wenn das React-Dashboard woanders gehostet wird (andere Domain):
# DASHBOARD_FRONTEND_URL=https://dash.DEINE-DOMAIN.de
# DASHBOARD_API_PREFIX=/api/v1
# DASHBOARD_CORS_ORIGINS=https://dash.DEINE-DOMAIN.de,https://www.DEINE-DOMAIN.de

# --- Vite-Build (dashboard-ui), falls Dashboard statisch ausgeliefert wird ---
# VITE_DASHBOARD_API_BASE_URL=https://bot.DEINE-DOMAIN.de
# Optional: VITE_DASHBOARD_API_PREFIX=/api/v1

# OAuth / Session (Pflicht wenn Dashboard-Login aktiv)
# DISCORD_CLIENT_SECRET=
# DASHBOARD_SESSION_SECRET=
# DASHBOARD_AUTH_GUILD_ID=
# DASHBOARD_GUILD_ID=
# DASHBOARD_ACCESS_ROLE_ID=
# DASHBOARD_OWNER_USER_ID=
